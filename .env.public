# BagBuddy - Public Configuration (committed to git)
# All credentials are held by the proxy server.
# Users only need their own LLM API key in .env

# Proxy server (holds Supabase/Stripe/Langfuse API credentials)
PROXY_BASE_URL=https://bagbuddy-proxy.wangkancheng1122.workers.dev

# Langfuse host (just for dashboard link display, no secret)
LANGFUSE_HOST=https://jp.cloud.langfuse.com

# Application
APP_HOST=0.0.0.0
APP_PORT=9000
