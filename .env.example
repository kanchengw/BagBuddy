# BagBuddy - User Configuration
# Copy this file to .env
# All service credentials are handled by the proxy.

# === Required: LLM API Key ===
LLM_API_KEY=your_qwen_api_key_here
LLM_MODEL=qwen3.6-flash
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v3

# === Proxy (pre-configured, just uncomment and set your LLM key above) ===
PROXY_BASE_URL=https://bagbuddy-proxy.wangkancheng1122.workers.dev
